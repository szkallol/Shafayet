<script>
  const cur = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  const stickyWorkPill = document.getElementById('stickyWorkPill');
  const stickyMenuPill = document.getElementById('stickyMenuPill');
  const nav = document.getElementById('nav');

  let mx = 0;
  let my = 0;
  let rx = 0;
  let ry = 0;
  let lastScrollY = window.scrollY;

  document.addEventListener('mousemove', e => {
    mx = e.clientX;
    my = e.clientY;
  });

  (function loop() {
    rx += (mx - rx) * .12;
    ry += (my - ry) * .12;

    if (cur && ring) {
      cur.style.left = mx - 4 + 'px';
      cur.style.top = my - 4 + 'px';
      ring.style.left = rx - 16 + 'px';
      ring.style.top = ry - 16 + 'px';
    }

    requestAnimationFrame(loop);
  })();

  function handleScrollMenu() {
    const currentScroll = window.scrollY;
    const isScrolled = currentScroll > 90;
    const scrollingDown = currentScroll > lastScrollY;

    if (nav) {
      nav.classList.toggle('menu-hidden', isScrolled);
    }

    if (!isScrolled) {
      stickyWorkPill?.classList.remove('is-visible');
      stickyMenuPill?.classList.remove('is-visible');
    } else if (scrollingDown) {
      stickyWorkPill?.classList.add('is-visible');
      stickyMenuPill?.classList.remove('is-visible');
    } else {
      stickyWorkPill?.classList.remove('is-visible');
      stickyMenuPill?.classList.add('is-visible');
    }

    lastScrollY = Math.max(currentScroll, 0);
  }

  window.addEventListener('scroll', handleScrollMenu);

  const obs = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 90);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: .1 });

  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  function countUp(el) {
    const target = +el.dataset.count;
    const dur = 1400;
    const start = performance.now();

    (function tick(now) {
      const p = Math.min((now - start) / dur, 1);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.floor(ease * target) + '+';

      if (p < 1) requestAnimationFrame(tick);
    })(start);
  }

  const cObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting && e.target.dataset.count) {
        countUp(e.target);
        cObs.unobserve(e.target);
      }
    });
  }, { threshold: .5 });

  document.querySelectorAll('[data-count]').forEach(el => cObs.observe(el));
</script>

</body>
</html>